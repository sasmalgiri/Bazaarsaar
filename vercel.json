{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["bom1"],
  "redirects": [
    { "source": "/refund-policy", "destination": "/refund", "permanent": true }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-prep",
      "schedule": "0 2 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 18 * * 5"
    },
    {
      "path": "/api/cron/broker-health",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/broker-sync",
      "schedule": "0 16 * * 1-5"
    }
  ]
}
