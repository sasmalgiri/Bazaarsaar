# ============================================
# BAZAARSAAR ENVIRONMENT CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BazaarSaar
NODE_ENV=development

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_APP_MODE=beta
NEXT_PUBLIC_BETA_MODE=true

# Persona features
NEXT_PUBLIC_FEATURE_SWING_TRADER=true
NEXT_PUBLIC_FEATURE_INVESTOR=true
NEXT_PUBLIC_FEATURE_OPTIONS_TRADER=true

# Data features (Phase 1: off)
NEXT_PUBLIC_FEATURE_ZERODHA=false
NEXT_PUBLIC_FEATURE_PORTFOLIO_IMPORT=false

# Intelligence features
NEXT_PUBLIC_FEATURE_DAILY_PACK=true
NEXT_PUBLIC_FEATURE_SIGNALS=true
NEXT_PUBLIC_FEATURE_SCREENER=false

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# DATA PIPELINE (Python workers)
# ============================================
DATABASE_URL=postgresql://...
YAHOO_FINANCE_ENABLED=true
NSE_API_ENABLED=true

# ============================================
# SECURITY
# ============================================
SYNC_SECRET_KEY=your-secure-random-key
CRON_SECRET=your-cron-secret

# ============================================
# ADMIN
# ============================================
ADMIN_EMAILS=admin@bazaarsaar.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@bazaarsaar.com
