# ============================================
# BAZAARSAAR ENVIRONMENT CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=https://bazaarsaar.com
# NODE_ENV is auto-set by Vercel — do not set manually

# ============================================
# APP MODE (valid values: beta | full)
# ============================================
NEXT_PUBLIC_APP_MODE=full
NEXT_PUBLIC_BETA_MODE=false

# ============================================
# FEATURE FLAGS (all default true unless noted)
# ============================================
NEXT_PUBLIC_FEATURE_SWING_TRADER=true
NEXT_PUBLIC_FEATURE_INVESTOR=true
NEXT_PUBLIC_FEATURE_OPTIONS_TRADER=true
NEXT_PUBLIC_FEATURE_ZERODHA=true
NEXT_PUBLIC_FEATURE_JOURNAL=true
NEXT_PUBLIC_FEATURE_BROKER_CONNECT=true
NEXT_PUBLIC_FEATURE_WEEKLY_REPORT=true
NEXT_PUBLIC_FEATURE_CSV_IMPORT=true
NEXT_PUBLIC_FEATURE_DATA_EXPORT=true
NEXT_PUBLIC_FEATURE_PRICING=false
NEXT_PUBLIC_FEATURE_PAYMENTS=false

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# ZERODHA KITE CONNECT
# ============================================
ZERODHA_API_KEY=your-kite-api-key
ZERODHA_API_SECRET=your-kite-api-secret
ZERODHA_TOKEN_ENCRYPTION_KEY=64-char-hex-key-for-aes-256

# ============================================
# SECURITY
# ============================================
CRON_SECRET=your-cron-secret

# ============================================
# ADMIN (comma-separated for multiple)
# ============================================
NEXT_PUBLIC_ADMIN_EMAILS=sasmalgiri@gmail.com
